{
  "name": "alamanac-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js conversion scaffold for Pyalmanac using an Inquirer CLI.",
  "bin": {
    "alamanac-js": "./src/cli.js"
  },
  "scripts": {

    "pdf": "node src/compile-tex.js",
    "test": "node --test"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "inquirer": "^12.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
